<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Campaigns — 3Folks Media</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/styles.css?v=45" />
  </head>
  <body class="admin-page">
    <div class="shell">

      <!-- Hero Banner Header -->
      <div class="topbar hero-banner folder-header-banner">
        <div class="header-left">
          <%- include('partials/brand') %>
          <div class="eyebrow">Team workspace</div>
          <h2 style="margin: 8px 0 6px 0;">Campaigns</h2>
          <p class="subtitle" style="color: #4B5563 !important;">Create campaigns and map creators by mobile number.</p>
        </div>

        <div class="header-right">
          <div class="header-actions-row">
            <a href="/admin/dashboard"><button class="btn btn-3d-nav" type="button">← Back</button></a>
          </div>
          <div class="header-stats-grid">
            <div class="header-stat-card">
              <span class="stat-icon">📣</span>
              <div class="stat-info">
                <span class="stat-value"><%= campaigns.length %></span>
                <span class="stat-label">Total Campaigns</span>
              </div>
            </div>
            <div class="header-stat-card">
              <span class="stat-icon">👥</span>
              <div class="stat-info">
                <span class="stat-value"><%= campaigns.reduce((s,c)=>s+(c.creator_count||0),0) %></span>
                <span class="stat-label">Total Creators</span>
              </div>
            </div>
            <div class="header-stat-card">
              <span class="stat-icon">💰</span>
              <div class="stat-info">
                <span class="stat-value">₹<%= Number(campaigns.reduce((s,c)=>s+Number(c.amount||0),0)).toLocaleString('en-IN',{minimumFractionDigits:0,maximumFractionDigits:0}) %></span>
                <span class="stat-label">Total Payout</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <!-- Add Campaign Form -->
      <% if (canEdit) { %>
        <div class="card glass-panel" style="margin-bottom: 16px;">
          <div class="section-head" style="margin-bottom: 20px;">
            <div>
              <h3>Add Campaign</h3>
              <p class="subtitle">Fill in campaign name, code and optionally assign a team.</p>
            </div>
          </div>
          <form method="post" action="/admin/campaigns" class="grid-3">
            <label class="input-label">
              <span>Campaign Name *</span>
              <input type="text" name="campaignName" required placeholder="e.g. Kaamil Phase 3" />
            </label>
            <label class="input-label">
              <span>Campaign Code *</span>
              <input type="text" name="campaignCode" required placeholder="e.g. 3FM-CC-40" />
            </label>
            <% if (user.role === 'SUPER_ADMIN') { %>
              <label class="input-label">
                <span>Team Name</span>
                <input type="text" name="teamName" placeholder="TEAM_1" />
              </label>
            <% } %>
            <div style="align-self: end;">
              <button class="btn btn-3d-nav" type="submit" style="width:100%;">+ Create Campaign</button>
            </div>
          </form>
        </div>
      <% } %>

      <!-- Filter -->
      <div class="card glass-panel" style="margin-bottom: 16px;">
        <form method="get" action="/admin/campaigns" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
          <label class="input-label" style="flex:1;min-width:220px;">
            <span>Search by name / code / team</span>
            <input type="text" name="search" value="<%= search || '' %>" placeholder="Kaamil, 3FM-CC-40…" />
          </label>
          <div style="display:flex;gap:8px;padding-bottom:2px;">
            <button class="btn btn-3d-nav" type="submit">Filter</button>
            <a href="/admin/campaigns"><button class="btn btn-3d-sm btn-3d-open" type="button" style="transform:none;">Clear</button></a>
          </div>
        </form>
      </div>

      <!-- Campaign List -->
      <div class="card glass-panel">
        <div class="section-head" style="margin-bottom: 20px;">
          <div>
            <h3>Campaign Folders</h3>
            <p class="subtitle">Click a campaign to view creators, amounts and invoices.</p>
          </div>
          <div class="pill"><%= campaigns.length %> campaigns</div>
        </div>

        <% if (!campaigns.length) { %>
          <div class="empty-state">No campaigns match your filter.</div>
        <% } %>

        <div class="folder-grid folder-grid-books" style="margin-top: 16px;">
          <% campaigns.forEach((c) => { %>
            <div class="folder-card-wrap">
              <a class="book" href="/admin/campaigns/<%= c.id %>/creators">

                <!-- Inside of Book (creators list) -->
                <div class="inside-page">
                  <div class="inside-header">Creators · <%= c.creators.length %></div>
                  <div class="inside-creators-list">
                    <% if (c.creators && c.creators.length) { %>
                      <% c.creators.forEach((cr) => { %>
                        <div class="inside-creator-row">
                          <span class="inside-creator-name"><%= cr.creator_name %></span>
                          <span class="inside-creator-amount">₹<%= Number(cr.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <div style="color:#a78bfa;font-size:13px;margin-top:16px;text-align:center;">No creators mapped</div>
                    <% } %>
                  </div>
                </div>

                <!-- Cover of Book (campaign summary) -->
                <div class="cover">
                  <div>
                    <span class="cover-tag">Campaign</span>
                    <h3 class="cover-title"><%= c.campaign_name %></h3>
                    <p style="font-size:12px;color:#6B7280;margin:0 0 12px 0;"><%= c.campaign_code %> · <%= c.team_name %></p>
                  </div>
                  <div class="cover-meta">
                    <div class="meta-item">
                      <span class="meta-icon">💰</span>
                      <span>₹<%= Number(c.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-icon">👥</span>
                      <span><%= c.creator_count || 0 %> creators</span>
                    </div>
                  </div>
                </div>

              </a>
            </div>
          <% }) %>
        </div>
      </div>

    </div>
  </body>
</html>
