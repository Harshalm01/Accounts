<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Campaigns</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="admin-page">
    <div class="shell">
      <div class="topbar">
        <div>
          <%- include('partials/brand') %>
          <h2>Campaigns</h2>
          <p class="subtitle">Create campaign with predefined amount and map creators by mobile.</p>
        </div>
        <a href="/admin/dashboard"><button class="btn btn-light" type="button">Back</button></a>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div class="card" style="margin-bottom: 12px;">
        <h3>Add Campaign</h3>
        <form method="post" action="/admin/campaigns" class="grid-3">
          <label>Campaign Name *<input type="text" name="campaignName" required /></label>
          <label>Campaign Code *<input type="text" name="campaignCode" required /></label>
          <% if (user.role === 'SUPER_ADMIN') { %>
            <label>Team Name<input type="text" name="teamName" placeholder="TEAM_1" /></label>
          <% } %>
          <div>
            <button class="btn btn-primary" type="submit">Create Campaign</button>
          </div>
        </form>
      </div>

      <div class="card" style="margin-bottom: 12px;">
        <h3>Filter Campaigns</h3>
        <p class="subtitle" style="margin-top: -6px;">Use search to narrow the list, for example by campaign name like Kaamil.</p>
        <form method="get" action="/admin/campaigns" class="grid-3">
          <label>
            Search by campaign name / code / team
            <input type="text" name="search" value="<%= search || '' %>" placeholder="Kaamil" />
          </label>
          <div style="align-self: end;">
            <button class="btn btn-dark" type="submit">Filter</button>
            <a href="/admin/campaigns"><button class="btn btn-light" type="button">Clear</button></a>
          </div>
        </form>
      </div>

      <div class="card glass-panel">
        <div class="section-head">
          <div>
            <h3>Campaign folders</h3>
            <p class="subtitle">Click a campaign name to see the creators, amounts, and invoice details inside it.</p>
          </div>
          <div class="pill"><%= campaigns.length %> campaigns</div>
        </div>

        <% if (!campaigns.length) { %>
          <div class="empty-state">No campaigns match your filter.</div>
        <% } %>

        <div class="folder-grid">
          <% campaigns.forEach((c) => { %>
            <details class="folder-card">
              <summary class="folder-summary">
                <h3><%= c.campaign_name %></h3>
              </summary>

              <div class="folder-card-body">
                <div class="folder-card-head">
                  <div>
                    <p class="subtitle"><%= c.campaign_code %> • <%= c.team_name %></p>
                    <div class="folder-metrics">
                      <span class="pill"><%= c.creator_count || 0 %> creators</span>
                      <span class="pill">₹<%= Number(c.amount || 0).toFixed(2) %></span>
                    </div>
                  </div>
                  <div class="folder-links">
                    <a href="/admin/campaigns/<%= c.id %>/creators">Manage Creators</a>
                  </div>
                </div>

                <div class="creator-stack">
                  <% const creators = c.creators || []; %>
                  <% if (!creators.length) { %>
                    <div class="empty-state empty-state-compact">No creators mapped yet.</div>
                  <% } %>
                  <% creators.forEach((creator) => { %>
                    <div class="creator-card-row">
                      <div>
                        <strong><%= creator.creator_name %></strong>
                        <div class="subtitle"><%= creator.mobile %></div>
                      </div>
                      <div class="creator-row-meta">
                        <span>₹<%= Number(creator.amount || 0).toFixed(2) %></span>
                        <span class="pill"><%= creator.invoice_count %> invoices</span>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </details>
          <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>