<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Invoice View</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="admin-page">
    <div class="shell">
      <% const isGstInvoice = invoice.invoice_type === 'gst'; %>
      <% const taxableAmount = Number(invoice.taxable_amount ?? invoice.locked_amount ?? invoice.total_amount ?? 0); %>
      <% const cgstAmount = Number(invoice.cgst_amount ?? (taxableAmount * 0.09).toFixed(2)); %>
      <% const sgstAmount = Number(invoice.sgst_amount ?? (taxableAmount * 0.09).toFixed(2)); %>
      <% const gstAmount = Number(invoice.gst_amount ?? (cgstAmount + sgstAmount).toFixed(2)); %>
      <% const grandTotal = Number(invoice.final_amount ?? (isGstInvoice ? (taxableAmount + gstAmount) : invoice.total_amount ?? taxableAmount)); %>
      <% function rowBreakup(amount) { const base = Number(amount || 0); const cgst = Number((base * 0.09).toFixed(2)); const sgst = Number((base * 0.09).toFixed(2)); return { cgst, sgst, finalAmount: Number((base + cgst + sgst).toFixed(2)) }; } %>
      <div class="topbar hero-banner">
        <div>
          <%- include('partials/brand') %>
          <div class="eyebrow">Invoice details</div>
          <h2>Invoice #<%= invoice.id %></h2>
          <div class="pill">Status: <%= invoice.status %></div>
        </div>
        <a href="/admin/dashboard"><button class="btn btn-light" type="button">Back</button></a>
      </div>

      <div class="card glass-panel" style="margin-bottom: 12px;">
        <div class="grid-3">
          <div><strong>Campaign:</strong> <%= invoice.campaign_name %> (<%= invoice.campaign_code %>)</div>
          <div><strong>Creator:</strong> <%= invoice.creator_name %> / <%= invoice.creator_mobile %></div>
          <div><strong>Total:</strong> <%= grandTotal.toFixed(2) %></div>
          <div><strong>Type:</strong> <%= isGstInvoice ? 'GST Based' : 'Non-GST Based' %></div>
          <div><strong>Invoice No:</strong> <%= invoice.invoice_no %></div>
          <div><strong>Date:</strong> <%= invoice.invoice_date %></div>
          <% if (isGstInvoice) { %>
            <div><strong>PO Number:</strong> <%= invoice.po_number || '' %></div>
            <div><strong>Creator GSTIN:</strong> <%= invoice.creator_gstin || '' %></div>
            <div><strong>Company GSTIN:</strong> 27AACFZ6393B1ZZ</div>
            <div><strong>Company PAN:</strong> AACFZ6393B</div>
            <div><strong>Taxable Amount:</strong> <%= taxableAmount.toFixed(2) %></div>
            <div><strong>CGST @ 9%:</strong> <%= cgstAmount.toFixed(2) %></div>
            <div><strong>SGST @ 9%:</strong> <%= sgstAmount.toFixed(2) %></div>
            <div><strong>Total GST:</strong> <%= gstAmount.toFixed(2) %></div>
            <div><strong>Grand Total:</strong> <%= grandTotal.toFixed(2) %></div>
          <% } %>
          <div><strong>PDF:</strong> <% if (invoice.pdf_path) { %><a href="<%= invoice.pdf_path %>" target="_blank">Download</a><% } else { %>Not generated<% } %></div>
        </div>
      </div>

      <div class="card glass-panel" style="margin-bottom: 12px;">
        <div class="section-head">
          <div>
            <h3>Rows</h3>
            <p class="subtitle">Invoice line items captured from the creator portal.</p>
          </div>
        </div>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Description</th>
              <th>Qty</th>
              <th>Rate</th>
              <% if (isGstInvoice) { %>
                <th>CGST</th>
                <th>SGST</th>
              <% } %>
              <th>Amount</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach((it, idx) => { %>
              <% const row = rowBreakup(it.amount); %>
              <tr>
                <td><%= idx + 1 %></td>
                <td><%= it.description %></td>
                <td><%= it.quantity %></td>
                <td><%= isGstInvoice ? '18.00' : Number(it.rate || 0).toFixed(2) %></td>
                <% if (isGstInvoice) { %>
                  <td><%= row.cgst.toFixed(2) %></td>
                  <td><%= row.sgst.toFixed(2) %></td>
                  <td><%= row.finalAmount.toFixed(2) %></td>
                <% } else { %>
                  <td><%= Number(it.amount || 0).toFixed(2) %></td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (isGstInvoice) { %>
        <div class="card glass-panel" style="margin-bottom: 12px;">
          <div class="section-head">
            <div>
              <h3>GST Summary</h3>
              <p class="subtitle">Automatic GST split applied on the commercial amount.</p>
            </div>
          </div>
          <table>
            <thead>
              <tr>
                <th>Taxable Amount</th>
                <th>CGST @ 9%</th>
                <th>SGST @ 9%</th>
                <th>Total GST</th>
                <th>Grand Total</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= Number(invoice.taxable_amount ?? invoice.locked_amount ?? 0).toFixed(2) %></td>
                <td><%= Number(invoice.cgst_amount ?? 0).toFixed(2) %></td>
                <td><%= Number(invoice.sgst_amount ?? 0).toFixed(2) %></td>
                <td><%= Number(invoice.gst_amount ?? 0).toFixed(2) %></td>
                <td><%= Number(invoice.final_amount ?? invoice.total_amount ?? 0).toFixed(2) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (user.role === 'ACCOUNTS' || user.role === 'SUPER_ADMIN') { %>
        <div class="card glass-panel">
          <div class="row">
            <a href="/admin/invoices/<%= invoice.id %>/edit"><button class="btn btn-dark" type="button">Edit Invoice</button></a>
            <form method="post" action="/admin/invoices/<%= invoice.id %>/status">
              <input type="hidden" name="action" value="accept" />
              <button class="btn btn-primary" type="submit">Accept</button>
            </form>
            <form method="post" action="/admin/invoices/<%= invoice.id %>/status">
              <input type="hidden" name="action" value="reject" />
              <button class="btn btn-danger" type="submit">Reject</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </body>
</html>