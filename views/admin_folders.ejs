<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Folders</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="admin-page">
    <div class="shell">
      <div class="topbar hero-banner">
        <div>
          <%- include('partials/brand') %>
          <div class="eyebrow">Accounts storage</div>
          <h2>Campaign Folders</h2>
          <p class="subtitle">Campaign folders are created automatically when a campaign is added.</p>
        </div>
        <a href="/admin/dashboard"><button class="btn btn-light" type="button">Back</button></a>
      </div>

      <div class="card glass-panel">
        <div class="section-head">
          <div>
            <h3>Available folders</h3>
            <p class="subtitle">Each campaign folder now shows the mapped creators inside the card.</p>
          </div>
          <div class="pill"><%= folders.length %> folders</div>
        </div>

        <% if (!folders.length) { %>
          <div class="empty-state">No campaign folders found yet.</div>
        <% } %>

        <div class="folder-grid">
          <% folders.forEach((folder) => { %>
            <details class="folder-card">
              <summary class="folder-summary">
                <h3><%= folder.campaignName %></h3>
              </summary>

              <div class="folder-card-body">
                <div class="folder-card-head">
                  <div>
                    <p class="subtitle"><%= folder.campaignCode %> • <%= folder.teamName %></p>
                    <div class="folder-metrics">
                      <span class="pill"><%= folder.creatorCount %> creators</span>
                      <span class="pill"><%= folder.invoiceCount %> invoices</span>
                    </div>
                  </div>
                </div>

                <div class="creator-stack">
                  <% if (!folder.creators.length) { %>
                    <div class="empty-state empty-state-compact">No creators mapped yet.</div>
                  <% } %>
                  <% folder.creators.forEach((creator) => { %>
                    <div class="creator-card-row">
                      <div>
                        <strong><%= creator.creator_name %></strong>
                        <div class="subtitle"><%= creator.mobile %></div>
                      </div>
                      <div class="creator-row-meta">
                        <span>₹<%= Number(creator.amount || 0).toFixed(2) %></span>
                        <span class="pill"><%= creator.invoice_count %> invoices</span>
                        <% if (creator.latest_invoice_id) { %>
                          <a class="creator-invoice-action" href="<%= creator.latest_pdf_path || `/admin/invoices/${creator.latest_invoice_id}` %>" target="<%= creator.latest_pdf_path ? '_blank' : '_self' %>">View / Download Invoice</a>
                        <% } else { %>
                          <span class="creator-invoice-action creator-invoice-action-disabled">No Invoice</span>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </details>
          <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>
