<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Folders</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="admin-page">
    <div class="shell">
      <div class="topbar hero-banner">
        <div>
          <%- include('partials/brand') %>
          <div class="eyebrow">Accounts storage</div>
          <h2>Campaign Folders</h2>
          <p class="subtitle">Campaign folders are created automatically when a campaign is added.</p>
        </div>
        <a href="/admin/dashboard"><button class="btn btn-light" type="button">Back</button></a>
      </div>

      <div class="card glass-panel">
        <div class="section-head">
          <div>
            <h3>Available folders</h3>
            <p class="subtitle">Each campaign folder now shows the mapped creators inside the card.</p>
          </div>
          <div class="pill"><%= folders.length %> folders</div>
        </div>

        <% if (!folders.length) { %>
          <div class="empty-state">No campaign folders found yet.</div>
        <% } %>

        <div class="folder-grid folder-grid-square">
          <% folders.forEach((folder) => { %>
            <a class="folder-card folder-card-square" href="/admin/campaigns/<%= folder.id %>/creators">
              <div class="folder-card-tile">
                <div class="folder-card-tile-top">
                  <span class="folder-card-label">Campaign</span>
                  <span class="folder-card-count"><%= folder.creatorCount %></span>
                </div>
                <h3 class="folder-card-title"><%= folder.campaignName %></h3>
                <p class="folder-card-subtitle"><%= folder.campaignCode %> • <%= folder.teamName %></p>
                <div class="folder-card-footer">
                  <span class="pill"><%= folder.invoiceCount %> invoices</span>
                  <span class="folder-card-link">Open</span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>
