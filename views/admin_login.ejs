<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login — 3Folks Media</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/styles.css?v=41" />
  </head>
  <body class="login-page">
    <div class="ambient-glow glow-1"></div>
    <div class="ambient-glow glow-2"></div>
    
    <div class="login-shell">
      <div class="login-main-container">
        <!-- Left Side: Form -->
        <div class="login-form-side">
          <header class="login-form-header">
            <div class="welcome-title">Welcome<span class="welcome-dot">.</span></div>
            <p class="subtitle">Sign in to manage campaigns, creators and payouts.</p>
          </header>

          <% if (error) { %>
            <div class="alert alert-error" style="margin-bottom: 20px;"><%= error %></div>
          <% } %>

          <form method="post" action="/admin/login" class="login-form login-form-premium">
            <label class="field field-floating">
              <input type="text" name="username" id="login-username" placeholder=" " required autocomplete="username" />
              <span>Username</span>
            </label>
            <label class="field field-floating field-password-wrap">
              <input type="password" name="password" id="login-password" placeholder=" " required autocomplete="current-password" />
              <span>Password</span>
              <button type="button" class="password-eye" id="togglePassword" tabindex="-1" aria-label="Show password">
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </label>
            
            <div class="login-row">
              <label class="login-remember">
                <input type="checkbox" />
                <span>Remember me</span>
              </label>
            </div>

            <button class="btn btn-login-cta" type="submit">
              <span>Sign In</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </form>
        </div>

        <!-- Right Side: Logo Brand -->
        <div class="login-brand-side">
          <!-- Decorative orbs inside the panel -->
          <div class="brand-orb brand-orb-1"></div>
          <div class="brand-orb brand-orb-2"></div>
          <div class="brand-side-content">
            <%- include('partials/brand') %>
          </div>
        </div>
      </div>
    </div>

    <script>
      const toggleBtn = document.getElementById('togglePassword');
      const pwdInput  = document.getElementById('login-password');
      const eyeIcon   = document.getElementById('eyeIcon');

      const eyeOpen = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
      const eyeOff  = `<line x1="17.94" y1="17.94" x2="23" y2="23"/><line x1="1" y1="1" x2="6.06" y2="6.06"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="12" x2="23" y2="12"/><!-- simplified -->`;

      if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
          const isPassword = pwdInput.type === 'password';
          pwdInput.type = isPassword ? 'text' : 'password';
          eyeIcon.innerHTML = isPassword ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>` : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>` ;
          toggleBtn.style.color = isPassword ? '#7c3aed' : '#94a3b8';
        });
      }
    </script>
  </body>
</html>

