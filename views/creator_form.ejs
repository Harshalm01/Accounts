<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Creator Portal</title>
    <link rel="stylesheet" href="/public/styles.css?v=45" />
  </head>
  <body class="creator-page">
    <div class="shell">
      <main class="portal-frame">
        <header class="portal-hero card">
          <div class="portal-title-block" style="display: flex; flex-direction: column; align-items: flex-start; gap: 12px; min-width: 0;">
            <div style="width: 160px; height: 60px; display: flex; align-items: center; justify-content: flex-start; margin-bottom: 4px; overflow: visible;">
              <img src="/public/logo.png" alt="3Folks Media" style="width: 100%; height: auto; max-height: 100%; object-fit: contain; display: block;" />
            </div>
            <div class="portal-kicker">Creator portal</div>
            <h1 style="margin: 0; font-size: clamp(2rem, 3.8vw, 36px); line-height: 1.1; letter-spacing: -0.03em; color: #111827;">Creator Invoice Portal</h1>
            <p class="subtitle" style="margin: 0; font-size: 14px; color: #6b7280;">Non-GST Bill of Supply submission</p>
          </div>
          <div class="portal-hero-meta" aria-hidden="true">
            <div class="meta-chip">
              <span class="meta-chip-label">Status</span>
              <strong>Secure submission</strong>
            </div>
            <div class="meta-chip">
              <span class="meta-chip-label">Flow</span>
              <strong>Validate, review, submit</strong>
            </div>
          </div>
        </header>

        <% if (error) { %>
          <section class="notice-card notice-error" role="alert">
            <div class="notice-icon notice-icon-error" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 9v4" />
                <path d="M12 17h.01" />
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
              </svg>
            </div>
            <div class="notice-copy">
              <h2>Check the highlighted fields</h2>
              <p><%= error %></p>
            </div>
          </section>
        <% } %>
        <% if (success) { %>
          <section class="notice-card notice-success" role="status" aria-live="polite">
            <div class="notice-icon notice-icon-success" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="m20 6-11 11-5-5" />
              </svg>
            </div>
            <div class="notice-copy">
              <p class="notice-kicker">Submission complete</p>
              <h2>Invoice Submitted Successfully</h2>
              <div class="notice-grid">
                <div>
                  <span>Review Timeline</span>
                  <strong>Verification • Approval • Release</strong>
                </div>
              </div>
            </div>
          </section>
        <% } %>

        <% if (!form.validated) { %>
          <section class="content-card">
            <div class="section-head">
              <div>
                <div class="portal-kicker">Campaign validation</div>
                <h2 class="section-title">Confirm the campaign mapping</h2>
              </div>
              <p class="section-subtitle">Enter the campaign code and registered serial number to unlock the invoice workflow.</p>
            </div>

            <form method="post" action="/creator/validate" class="portal-form">
              <div class="grid-2">
                <label class="field field-floating">
                  <input type="text" name="campaignCode" value="<%= form.campaignCode || '' %>" placeholder=" " required />
                  <span>Campaign Code *</span>
                </label>
                <label class="field field-floating">
                  <input type="text" name="mobile" value="<%= form.mobile || '' %>" placeholder=" " required />
                  <span>Serial Number *</span>
                </label>
              </div>
              <div class="form-actions form-actions-left">
                <button class="btn btn-3d-nav btn-3d-view btn-submit" type="submit" style="width: 100%; max-width: 280px;">
                  <span>Validate Campaign</span>
                </button>
              </div>
            </form>
          </section>
        <% } %>

        <% if (form.validated) { %>
          <% const existingInvoice = form.existingInvoice || null; %>
          <% const existingItems = form.existingItems || []; %>
          <% const selectedInvoiceType = existingInvoice ? existingInvoice.invoice_type : (form.invoiceType || 'non_gst'); %>
          <% const existingInvoiceItems = existingItems; %>

          <section class="notice-card info-card">
            <div class="notice-icon notice-icon-info" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 16v-4" />
                <path d="M12 8h.01" />
                <circle cx="12" cy="12" r="9" />
              </svg>
            </div>
            <div class="notice-copy">
              <p class="notice-kicker">Campaign validated</p>
              <h2><%= form.campaignName %></h2>
              <div class="summary-grid">
                <div class="summary-item">
                  <span>Brand</span>
                  <strong>3Folks Media</strong>
                </div>
                <div class="summary-item">
                  <span>Campaign Code</span>
                  <strong><%= form.campaignCode %></strong>
                </div>
                <div class="summary-item">
                  <span>Creator</span>
                  <strong><%= form.creatorName || '' %></strong>
                </div>
                <div class="summary-item">
                  <span>Amount</span>
                  <strong>₹<%= form.amount %></strong>
                </div>
              </div>
            </div>
          </section>

          <div class="mobile-preview-toggle">
            <button type="button" class="active" id="showFormBtn">Edit Form</button>
            <button type="button" id="showPreviewBtn">Live Preview</button>
          </div>

          <div class="portal-split-layout">
            <!-- LEFT PANEL: Stepper form -->
            <div class="portal-form-pane" id="formPane">
              <!-- Stepper Header -->
              <div class="stepper-header">
                <div class="stepper-progress-bar" id="stepperProgressBar"></div>
                <button type="button" class="step-bubble active" data-step="1">
                  <span class="step-number">1</span>
                  <span class="step-label">Identity</span>
                </button>
                <button type="button" class="step-bubble" data-step="2">
                  <span class="step-number">2</span>
                  <span class="step-label">Invoice</span>
                </button>
                <button type="button" class="step-bubble" data-step="3">
                  <span class="step-number">3</span>
                  <span class="step-label">Payout</span>
                </button>
                <button type="button" class="step-bubble" data-step="4">
                  <span class="step-number">4</span>
                  <span class="step-label">Sign</span>
                </button>
              </div>

              <form method="post" action="/creator/submit" enctype="multipart/form-data" id="invoiceForm" class="portal-form stack-layout">
                <input type="hidden" name="validated" value="true" />
                <input type="hidden" name="invoiceType" id="invoiceType" value="<%= selectedInvoiceType %>" />
                <% if (existingInvoice) { %>
                  <input type="hidden" name="existingInvoiceId" value="<%= existingInvoice.id %>" />
                <% } %>
                <input type="hidden" name="campaignId" value="<%= form.campaignId %>" />
                <input type="hidden" name="campaignCode" value="<%= form.campaignCode %>" />
                <input type="hidden" name="campaignName" value="<%= form.campaignName %>" />
                <input type="hidden" name="mobile" value="<%= form.mobile %>" />
                <input type="hidden" name="creatorName" value="<%= form.creatorName || '' %>" />
                <input type="hidden" name="amount" value="<%= form.amount %>" />
                <input type="hidden" id="signatureDraw" name="signatureDraw" />

                <!-- STEP 1: Billing Choice & Profile -->
                <div class="stepper-step active" data-step="1">
                  <div class="content-card" style="margin-bottom: 20px;">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Invoice type</div>
                        <h2 class="section-title">Choose the billing flow</h2>
                      </div>
                    </div>
                    <div class="grid-2 choice-grid">
                      <button type="button" class="btn btn-light flow-choice" id="nonGstChoice">
                        <span>Non-GST Based</span>
                      </button>
                      <button type="button" class="btn btn-light flow-choice" id="gstChoice">
                        <span>GST Based</span>
                      </button>
                    </div>
                    <p class="section-subtitle" id="choiceHint" style="margin-top: 10px;">Select to configure invoice settings.</p>
                  </div>

                  <div class="content-card">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Billing identity</div>
                        <h2 class="section-title">Bill from</h2>
                      </div>
                    </div>
                    <div class="grid-2 field-grid">
                      <label class="field field-floating">
                        <input type="text" name="fullName" value="<%= existingInvoice ? existingInvoice.full_name : (form.fullName || '') %>" required placeholder=" " />
                        <span>Full Name *</span>
                        <small class="validation-msg">Full Name is required.</small>
                      </label>
                      <label class="field field-floating field-textarea">
                        <textarea name="address" required placeholder=" "><%= existingInvoice ? existingInvoice.address || '' : (form.address || '') %></textarea>
                        <span>Address *</span>
                        <small class="validation-msg">Address is required.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="pan" value="<%= existingInvoice ? existingInvoice.pan || '' : (form.pan || '') %>" pattern="[A-Z]{5}[0-9]{4}[A-Z]" title="PAN format: ABCDE1234F" autocapitalize="characters" placeholder=" " />
                        <span>PAN/IT No</span>
                        <small class="validation-msg">Invalid PAN format (e.g. ABCDE1234F).</small>
                      </label>
                      <label class="field field-floating">
                        <input type="email" name="email" value="<%= existingInvoice ? existingInvoice.email || '' : (form.email || '') %>" placeholder=" " />
                        <span>Email</span>
                        <small class="validation-msg">Invalid email format.</small>
                      </label>
                    </div>
                  </div>

                  <div class="form-actions form-actions-right" style="margin-top: 20px;">
                    <button type="button" class="btn btn-3d-nav btn-3d-view btn-next">Next Step</button>
                  </div>
                </div>

                <!-- STEP 2: Invoice Details -->
                <div class="stepper-step" data-step="2">
                  <div class="content-card" style="margin-bottom: 20px;">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Document control</div>
                        <h2 class="section-title">Invoice header</h2>
                      </div>
                    </div>
                    <div class="grid-3 field-grid">
                      <label class="field field-floating">
                        <input type="text" name="invoiceNo" value="<%= existingInvoice ? existingInvoice.invoice_no || '' : (form.invoiceNo || '') %>" required placeholder=" " />
                        <span>Invoice No *</span>
                        <small class="validation-msg">Invoice No is required.</small>
                      </label>
                      <label class="field field-floating field-readonly">
                        <input type="date" name="invoiceDate" value="<%= today %>" readonly required placeholder=" " />
                        <span>Dated Today *</span>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="paymentMode" value="<%= existingInvoice ? existingInvoice.payment_mode || '' : (form.paymentMode || '') %>" placeholder=" " />
                        <span>Mode/Terms of Payment</span>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="pocName" value="<%= existingInvoice ? existingInvoice.poc_name || '' : (form.pocName || '') %>" placeholder=" " />
                        <span>POC Name</span>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="otherReferences" value="<%= existingInvoice ? existingInvoice.other_references || '' : (form.otherReferences || '') %>" placeholder=" " />
                        <span>Other References</span>
                      </label>
                    </div>
                  </div>

                  <div class="content-card" id="gstDetailsSection" hidden>
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">GST details</div>
                        <h2 class="section-title">GST invoice requirements</h2>
                      </div>
                    </div>
                    <div class="grid-2 field-grid">
                      <label class="field field-floating">
                        <input type="text" name="poNumber" id="poNumber" value="<%= existingInvoice ? existingInvoice.po_number || '' : (form.poNumber || '') %>" placeholder=" " />
                        <span>PO Number *</span>
                        <small class="validation-msg">PO Number is required for GST.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="gstin" id="gstin" value="<%= existingInvoice ? existingInvoice.creator_gstin || '' : (form.gstin || '') %>" pattern="[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][1-9A-Z]Z[0-9A-Z]" title="GSTIN format: 27ABCDE1234F1Z5" autocapitalize="characters" placeholder=" " />
                        <span>GSTIN of Creator *</span>
                        <small class="validation-msg">Invalid GSTIN format (e.g. 27ABCDE1234F1Z5).</small>
                      </label>
                    </div>
                  </div>

                  <div class="form-actions form-actions-between" style="margin-top: 20px;">
                    <button type="button" class="btn btn-3d-sm btn-3d-open btn-prev">Back</button>
                    <button type="button" class="btn btn-3d-nav btn-3d-view btn-next">Next Step</button>
                  </div>
                </div>

                <!-- STEP 3: Line Items & Payout details -->
                <div class="stepper-step" data-step="3">
                  <div class="content-card" style="margin-bottom: 20px;">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Line items</div>
                        <h2 class="section-title">Invoice rows</h2>
                      </div>
                      <p class="section-subtitle">Amount is auto-allocated from the locked creator commercial (₹<%= form.amount %>).</p>
                    </div>
                    <input type="number" id="lockedAmount" value="<%= form.amount %>" hidden />
                    <div class="invoice-rows" id="rowsWrap"></div>
                    <div class="form-actions form-actions-between" style="margin-top: 10px;">
                      <button type="button" class="btn btn-light" id="addRowBtn">+ Add Row</button>
                      <label class="field field-floating field-readonly compact-field">
                        <input type="number" id="computedTotal" readonly placeholder=" " />
                        <span>Auto Total</span>
                      </label>
                    </div>
                  </div>

                  <div class="content-card">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Payout rails</div>
                        <h2 class="section-title">Bank details</h2>
                      </div>
                    </div>
                    <div class="grid-3 field-grid">
                      <label class="field field-floating">
                        <input type="text" name="accountName" value="<%= existingInvoice ? existingInvoice.account_name || '' : (form.accountName || '') %>" required placeholder=" " />
                        <span>Account Name *</span>
                        <small class="validation-msg">Account Name is required.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="bankName" value="<%= existingInvoice ? existingInvoice.bank_name || '' : (form.bankName || '') %>" required placeholder=" " />
                        <span>Bank Name *</span>
                        <small class="validation-msg">Bank Name is required.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="accountNo" value="<%= existingInvoice ? existingInvoice.account_no || '' : (form.accountNo || '') %>" required placeholder=" " />
                        <span>Account No *</span>
                        <small class="validation-msg">Account Number is required.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="ifscCode" value="<%= existingInvoice ? existingInvoice.ifsc_code || '' : (form.ifscCode || '') %>" required pattern="[A-Z]{4}0[A-Z0-9]{6}" title="IFSC format: SBIN0001234" autocapitalize="characters" placeholder=" " />
                        <span>IFSC Code *</span>
                        <small class="validation-msg">Invalid IFSC Code (e.g. SBIN0001234).</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="branch" value="<%= existingInvoice ? existingInvoice.branch || '' : (form.branch || '') %>" required placeholder=" " />
                        <span>Branch *</span>
                        <small class="validation-msg">Branch is required.</small>
                      </label>
                      <label class="field field-floating">
                        <input type="text" name="upiId" value="<%= existingInvoice ? existingInvoice.upi_id || '' : (form.upiId || '') %>" placeholder=" " />
                        <span>UPI ID</span>
                      </label>
                    </div>
                  </div>

                  <div class="form-actions form-actions-between" style="margin-top: 20px;">
                    <button type="button" class="btn btn-3d-sm btn-3d-open btn-prev">Back</button>
                    <button type="button" class="btn btn-3d-nav btn-3d-view btn-next">Next Step</button>
                  </div>
                </div>

                <!-- STEP 4: Review & Sign -->
                <div class="stepper-step" data-step="4">
                  <div class="content-card">
                    <div class="section-head">
                      <div>
                        <div class="portal-kicker">Signature capture</div>
                        <h2 class="section-title">E-sign</h2>
                      </div>
                      <p class="section-subtitle">Draw signature or upload signature image before final submission.</p>
                    </div>
                    <div class="grid-2 signature-grid">
                      <div class="signature-panel">
                        <label class="field-label-inline">Draw Signature</label>
                        <div class="canvas-wrap">
                          <canvas id="signPad" width="600" height="160"></canvas>
                        </div>
                        <div class="form-actions form-actions-left" style="margin-top: 6px;">
                          <button type="button" class="btn btn-3d-sm btn-3d-open" id="clearSign">Clear Drawing</button>
                        </div>
                      </div>
                      <div class="signature-upload-panel">
                        <label class="field-label-inline" for="signatureFile">Or Upload Signature Image</label>
                        <input type="file" id="signatureFile" name="signatureFile" accept="image/*" />
                        <p class="subtitle" style="margin: 6px 0 0;">PNG, JPG, or JPEG works best.</p>
                      </div>
                    </div>
                  </div>

                  <div class="form-actions form-actions-between" style="margin-top: 20px;">
                    <button type="button" class="btn btn-3d-sm btn-3d-open btn-prev">Back</button>
                    <button class="btn btn-3d-nav btn-3d-accept btn-submit" type="submit" id="submitBtn">
                      <span class="btn-spinner" aria-hidden="true"></span>
                      <span class="btn-label">Submit Invoice</span>
                    </button>
                  </div>
                </div>
              </form>
            </div>

            <!-- RIGHT PANEL: Live preview paper card -->
            <div class="portal-preview-pane" id="previewPane">
              <div class="live-invoice-paper">
                <div>
                  <h2 id="prevInvoiceTitle">BILL OF SUPPLY</h2>

                  <div class="preview-header-meta">
                    <div>
                      <div class="preview-title">Bill From</div>
                      <div style="font-weight: 600;" id="prevCreatorName">-</div>
                      <div id="prevCreatorAddress" style="white-space: pre-wrap; font-size: 10px; color: #555;">-</div>
                      <div id="prevCreatorEmail" style="color: #555;">-</div>
                      <div id="prevCreatorPan" style="font-weight: 500;">-</div>
                      <div id="prevCreatorGstinBlock" style="display:none; font-weight: 500;">GSTIN: <span id="prevCreatorGstin">-</span></div>
                    </div>
                    <div style="text-align: right;">
                      <div class="preview-title">Bill To</div>
                      <div style="font-weight: 600;">3Folks Media</div>
                      <div style="font-size: 10px; color: #555;">1801, 18th Floor, C Wing, Lotus Corporate Park, Off. Western Express Highway, Goregaon East, Mumbai- 400063.</div>
                      <div style="font-weight: 500;">PAN: AACFZ6393B</div>
                      <div style="font-weight: 500;">GSTIN: 27AACFZ6393B1ZZ</div>
                    </div>
                  </div>

                  <div class="preview-grid-2" style="border-top: 1px solid #e5e5ea; padding-top: 8px; font-size: 10px; color: #333;">
                    <div>
                      <div><strong>Invoice No:</strong> <span id="prevInvoiceNo">-</span></div>
                      <div><strong>Date:</strong> <span id="prevInvoiceDate">-</span></div>
                      <div><strong>Payment Mode:</strong> <span id="prevPaymentMode">-</span></div>
                    </div>
                    <div style="text-align: right;">
                      <div><strong>POC Name:</strong> <span id="prevPocName">-</span></div>
                      <div><strong>References:</strong> <span id="prevReferences">-</span></div>
                      <div id="prevPoBlock" style="display:none;"><strong>PO Number:</strong> <span id="prevPoNumber">-</span></div>
                    </div>
                  </div>

                  <table class="preview-table">
                    <thead>
                      <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 55%;">Description</th>
                        <th style="width: 20%; text-align: right;">Qty</th>
                        <th style="width: 20%; text-align: right;">Amount</th>
                      </tr>
                    </thead>
                    <tbody id="prevTableBody">
                      <!-- Dynamically added rows -->
                    </tbody>
                  </table>
                </div>

                <div>
                  <div style="display: flex; justify-content: space-between; align-items: flex-end; border-top: 1px solid #e5e5ea; padding-top: 8px;">
                    <div style="width: 50%; font-size: 10px; line-height: 1.3;">
                      <div class="preview-title" style="border-bottom: none; margin-bottom: 2px;">Bank Details</div>
                      <div><strong>Account Name:</strong> <span id="prevAccName">-</span></div>
                      <div><strong>Bank Name:</strong> <span id="prevBankName">-</span></div>
                      <div><strong>Account No:</strong> <span id="prevAccNo">-</span></div>
                      <div><strong>IFSC Code:</strong> <span id="prevIfsc">-</span></div>
                      <div><strong>Branch:</strong> <span id="prevBranch">-</span></div>
                      <div><strong>UPI ID:</strong> <span id="prevUpi">-</span></div>
                    </div>

                    <div class="preview-totals">
                      <div id="prevTaxableRow" class="preview-totals-row" style="display:none;">
                        <span>Taxable Value:</span>
                        <span id="prevTaxableAmount">₹0.00</span>
                      </div>
                      <div id="prevCgstRow" class="preview-totals-row" style="display:none;">
                        <span id="prevCgstLabel">CGST @ 9%:</span>
                        <span id="prevCgstAmount">₹0.00</span>
                      </div>
                      <div id="prevSgstRow" class="preview-totals-row" style="display:none;">
                        <span>SGST @ 9%:</span>
                        <span id="prevSgstAmount">₹0.00</span>
                      </div>
                      <div id="prevGstRow" class="preview-totals-row" style="display:none;">
                        <span>Total GST:</span>
                        <span id="prevGstAmount">₹0.00</span>
                      </div>
                      <div class="preview-totals-row grand-total">
                        <span>Grand Total:</span>
                        <span id="prevGrandTotal">₹0.00</span>
                      </div>
                    </div>
                  </div>

                  <div class="preview-signature-wrap">
                    <div>
                      <img id="prevSignatureImg" class="preview-signature-img" style="display:none;" />
                      <div style="border-top: 1px solid #d1d1d6; padding-top: 4px; font-weight: 500; font-size: 9px; color: #555;">Authorised Signatory</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </main>
    </div>

    <% if (form.validated) { %>
      <script>
        const nonGstChoice = document.getElementById("nonGstChoice");
        const gstChoice = document.getElementById("gstChoice");
        const gstDetailsSection = document.getElementById("gstDetailsSection");
        const invoiceType = document.getElementById("invoiceType");
        const poNumber = document.getElementById("poNumber");
        const gstin = document.getElementById("gstin");
        const rowsWrap = document.getElementById("rowsWrap");
        const addRowBtn = document.getElementById("addRowBtn");
        const lockedAmount = Number(document.getElementById("lockedAmount").value || 0);
        const computedTotal = document.getElementById("computedTotal");
        const formEl = document.getElementById("invoiceForm");
        const submitBtn = document.getElementById("submitBtn");
        const initialItems = <%- JSON.stringify(form.existingItems || []) %>;
        const deliverableOptions = <%- JSON.stringify(deliverableOptions) %>;
        const companyStateCode = "27";

        // Mobile preview toggle buttons
        const showFormBtn = document.getElementById("showFormBtn");
        const showPreviewBtn = document.getElementById("showPreviewBtn");
        const formPane = document.getElementById("formPane");
        const previewPane = document.getElementById("previewPane");

        if (showFormBtn && showPreviewBtn) {
          showFormBtn.addEventListener("click", () => {
            showFormBtn.classList.add("active");
            showPreviewBtn.classList.remove("active");
            formPane.classList.remove("inactive");
            previewPane.classList.remove("active");
          });
          showPreviewBtn.addEventListener("click", () => {
            showPreviewBtn.classList.add("active");
            showFormBtn.classList.remove("active");
            formPane.classList.add("inactive");
            previewPane.classList.add("active");
          });
        }

        // Stepper Navigation
        let currentStep = 1;
        const steps = document.querySelectorAll(".stepper-step");
        const stepBubbles = document.querySelectorAll(".step-bubble");
        const progressBar = document.getElementById("stepperProgressBar");

        function updateStepUI() {
          steps.forEach((step) => {
            step.classList.toggle("active", Number(step.dataset.step) === currentStep);
          });

          stepBubbles.forEach((bubble) => {
            const stepNum = Number(bubble.dataset.step);
            bubble.classList.toggle("active", stepNum === currentStep);
            bubble.classList.toggle("completed", stepNum < currentStep);
          });

          const percentages = [0, 33.33, 66.66, 100];
          progressBar.style.width = `calc(${percentages[currentStep - 1]}% - 20px)`;
          progressBar.style.left = "20px";
          window.scrollTo({ top: 0, behavior: "smooth" });
        }

        function validateField(inputEl) {
          const fieldContainer = inputEl.closest(".field");
          if (!fieldContainer) return true;

          if (inputEl.closest("[hidden]")) {
            fieldContainer.classList.remove("is-valid", "is-invalid");
            return true;
          }

          let isValid = true;
          const val = inputEl.value.trim();

          if (inputEl.hasAttribute("required") && !val) {
            isValid = false;
          } else if (val) {
            if (inputEl.type === "email") {
              const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
              isValid = emailRegex.test(val);
            } else if (inputEl.hasAttribute("pattern")) {
              const patternRegex = new RegExp("^" + inputEl.getAttribute("pattern") + "$");
              isValid = patternRegex.test(val);
            }
          }

          if (isValid) {
            fieldContainer.classList.add("is-valid");
            fieldContainer.classList.remove("is-invalid");
          } else {
            fieldContainer.classList.add("is-invalid");
            fieldContainer.classList.remove("is-valid");
          }
          return isValid;
        }

        function validateCurrentStep() {
          const activeStepContainer = document.querySelector(`.stepper-step[data-step='${currentStep}']`);
          if (!activeStepContainer) return true;

          const inputs = activeStepContainer.querySelectorAll("input, textarea, select");
          let stepValid = true;
          inputs.forEach((input) => {
            const ok = validateField(input);
            if (!ok) stepValid = false;
          });

          return stepValid;
        }

        document.querySelectorAll(".btn-next").forEach((btn) => {
          btn.addEventListener("click", () => {
            if (validateCurrentStep()) {
              currentStep += 1;
              updateStepUI();
            }
          });
        });

        document.querySelectorAll(".btn-prev").forEach((btn) => {
          btn.addEventListener("click", () => {
            if (currentStep > 1) {
              currentStep -= 1;
              updateStepUI();
            }
          });
        });

        stepBubbles.forEach((bubble) => {
          bubble.addEventListener("click", () => {
            const targetStep = Number(bubble.dataset.step);
            if (targetStep < currentStep) {
              currentStep = targetStep;
              updateStepUI();
            } else if (targetStep === currentStep + 1 && validateCurrentStep()) {
              currentStep = targetStep;
              updateStepUI();
            }
          });
        });

        updateStepUI();

        // GST choice handling
        function setChoiceState(activeChoice) {
          if (nonGstChoice) {
            nonGstChoice.classList.toggle("flow-choice-active", activeChoice === "non_gst");
          }
          if (gstChoice) {
            gstChoice.classList.toggle("flow-choice-active", activeChoice === "gst");
          }
        }

        function showNonGstFlow() {
          if (invoiceType) invoiceType.value = "non_gst";
          if (choiceHint) choiceHint.textContent = "Non-GST based Bill of Supply flow selected. Fill details below.";
          setChoiceState("non_gst");
          if (gstDetailsSection) gstDetailsSection.hidden = true;
          if (poNumber) poNumber.required = false;
          if (gstin) gstin.required = false;
          syncAllPreviewFields();
        }

        function showGstFlow() {
          if (invoiceType) invoiceType.value = "gst";
          if (choiceHint) choiceHint.textContent = "GST based Tax Invoice flow selected. PO Number and GSTIN are required.";
          setChoiceState("gst");
          if (gstDetailsSection) gstDetailsSection.hidden = false;
          if (poNumber) poNumber.required = true;
          if (gstin) gstin.required = true;
          syncAllPreviewFields();
        }

        if (nonGstChoice) nonGstChoice.addEventListener("click", showNonGstFlow);
        if (gstChoice) gstChoice.addEventListener("click", showGstFlow);

        if (invoiceType && invoiceType.value === "gst") {
          showGstFlow();
        } else {
          showNonGstFlow();
        }

        // Real-Time Live Preview Sync and Validation
        function syncFieldState(field) {
          const control = field.querySelector("input, textarea, select");
          if (!control) return;
          const hasValue = control.type === "file"
            ? Boolean(control.files && control.files.length)
            : Boolean(String(control.value || "").trim());
          field.dataset.filled = hasValue ? "true" : "false";
        }

        function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/\"/g, "&quot;");
        }

        function updatePreviewTable() {
          const tableBody = document.getElementById("prevTableBody");
          if (!tableBody) return;
          tableBody.innerHTML = "";

          const rows = document.querySelectorAll(".line-item-row");
          rows.forEach((row, index) => {
            const descSelect = row.querySelector("select[name='itemDescriptions']");
            const customInput = row.querySelector("input[name='itemCustomDescriptions']");
            const qtyInput = row.querySelector("input[name='itemQuantities']");
            const amtInput = row.querySelector("input[name='itemAmounts']");

            const desc = descSelect && descSelect.value === "Custom" ? (customInput ? customInput.value : "") : (descSelect ? descSelect.value : "");
            const qty = Number(qtyInput ? qtyInput.value : 0);
            const amt = Number(amtInput ? amtInput.value : 0);

            const tr = document.createElement("tr");
            tr.innerHTML = `
              <td>${index + 1}</td>
              <td style="word-break: break-all;">${escapeHtml(desc || "-")}</td>
              <td style="text-align: right;">${qty.toFixed(2)}</td>
              <td style="text-align: right;">₹${amt.toFixed(2)}</td>
            `;
            tableBody.appendChild(tr);
          });
        }

        function updatePreviewTotals() {
          const isGst = invoiceType.value === "gst";
          const taxable = Number(lockedAmount || 0);
          const gstinValue = String(gstin ? gstin.value : "").trim();
          const isIntraState = gstinValue.slice(0, 2) === companyStateCode;

          const cgst = isIntraState ? Number((taxable * 0.09).toFixed(2)) : 0;
          const sgst = isIntraState ? Number((taxable * 0.09).toFixed(2)) : 0;
          const igst = isIntraState ? 0 : Number((taxable * 0.18).toFixed(2));
          const totalGst = Number((cgst + sgst + igst).toFixed(2));
          const final = Number((taxable + totalGst).toFixed(2));

          document.getElementById("prevTaxableRow").style.display = isGst ? "flex" : "none";
          document.getElementById("prevGstRow").style.display = isGst ? "flex" : "none";
          document.getElementById("prevCgstRow").style.display = isGst ? "flex" : "none";
          document.getElementById("prevSgstRow").style.display = isGst && isIntraState ? "flex" : "none";

          if (isGst) {
            document.getElementById("prevTaxableAmount").textContent = "₹" + taxable.toFixed(2);
            document.getElementById("prevCgstLabel").textContent = isIntraState ? "CGST @ 9%:" : "IGST @ 18%:";
            document.getElementById("prevCgstAmount").textContent = "₹" + (isIntraState ? cgst : igst).toFixed(2);
            document.getElementById("prevSgstAmount").textContent = "₹" + sgst.toFixed(2);
            document.getElementById("prevGstAmount").textContent = "₹" + totalGst.toFixed(2);
            document.getElementById("prevGrandTotal").textContent = "₹" + final.toFixed(2);
          } else {
            document.getElementById("prevGrandTotal").textContent = "₹" + taxable.toFixed(2);
          }
        }

        function syncAllPreviewFields() {
          const fieldsMap = {
            "fullName": "prevCreatorName",
            "address": "prevCreatorAddress",
            "email": "prevCreatorEmail",
            "pan": "prevCreatorPan",
            "invoiceNo": "prevInvoiceNo",
            "paymentMode": "prevPaymentMode",
            "pocName": "prevPocName",
            "otherReferences": "prevReferences",
            "poNumber": "prevPoNumber",
            "gstin": "prevCreatorGstin",
            "accountName": "prevAccName",
            "bankName": "prevBankName",
            "accountNo": "prevAccNo",
            "ifscCode": "prevIfsc",
            "branch": "prevBranch",
            "upiId": "prevUpi"
          };

          for (const [name, prevId] of Object.entries(fieldsMap)) {
            const input = document.querySelector(`[name='${name}']`);
            const prevEl = document.getElementById(prevId);
            if (input && prevEl) {
              prevEl.textContent = input.value.trim() || "-";
              if (name === "pan") {
                prevEl.textContent = input.value.trim() ? "PAN: " + input.value.trim().toUpperCase() : "-";
              }
            }
          }

          const dateInput = document.querySelector("input[name='invoiceDate']");
          if (dateInput) {
            document.getElementById("prevInvoiceDate").textContent = dateInput.value || "-";
          }

          const isGst = invoiceType.value === "gst";
          document.getElementById("prevCreatorGstinBlock").style.display = isGst ? "block" : "none";
          document.getElementById("prevPoBlock").style.display = isGst ? "block" : "none";
          document.getElementById("prevInvoiceTitle").textContent = isGst ? "TAX INVOICE" : "BILL OF SUPPLY";

          updatePreviewTable();
          updatePreviewTotals();
        }

        // Live validation and preview mapping setup
        function bindLiveInput(inputEl) {
          const field = inputEl.closest(".field");
          if (field) syncFieldState(field);

          ["input", "change", "blur"].forEach((eventName) => {
            inputEl.addEventListener(eventName, () => {
              if (field) syncFieldState(field);
              validateField(inputEl);
              syncAllPreviewFields();
            });
          });
        }

        document.querySelectorAll("input, textarea, select").forEach((input) => {
          bindLiveInput(input);
        });

        // Line Items templates and calculations
        function rowTemplate(item = {}) {
          const description = String(item.description || "").trim();
          const isCustom = Boolean(description) && !deliverableOptions.includes(description);
          const selectedValue = isCustom ? "Custom" : (description || deliverableOptions[0] || "");
          const customValue = isCustom ? description : "";
          const rowAmount = Number.isFinite(Number(item.amount)) ? Number(item.amount) : 0;
          const row = document.createElement("div");
          row.className = "invoice-row-wrap";
          row.style.marginBottom = "10px";
          row.innerHTML = `
            <div class="grid-3 line-item-row" style="position:relative;">
              <label class="field field-floating">
                <select name="itemDescriptions" required placeholder=" ">
                  ${deliverableOptions.map((option) => `<option value="${escapeHtml(option)}" ${selectedValue === option ? "selected" : ""}>${escapeHtml(option)}</option>`).join("")}
                  <option value="Custom" ${selectedValue === "Custom" ? "selected" : ""}>Custom</option>
                </select>
                <span>Deliverable *</span>
              </label>
              <label class="field field-floating">
                <input type="number" name="itemQuantities" step="0.01" min="0" value="${Number(item.quantity || 1)}" required placeholder=" " />
                <span>Quantity *</span>
              </label>
              <label class="field field-floating field-readonly">
                <input type="number" name="itemAmounts" step="0.01" min="0" value="${rowAmount.toFixed(2)}" readonly required placeholder=" " />
                <span>Amount</span>
              </label>
              <label class="field field-floating field-textarea custom-deliverable" style="grid-column: 1 / -1; margin-top: 8px; ${selectedValue === "Custom" ? "" : "display:none;"}">  
                <input type="text" name="itemCustomDescriptions" value="${escapeHtml(customValue)}" placeholder=" " ${selectedValue === "Custom" ? "required" : ""} />
                <span>Custom Deliverable</span>
              </label>
              <button type="button" class="delete-row-btn" title="Remove this row" aria-label="Delete row">✕</button>
            </div>
          `;

          const select = row.querySelector("select[name='itemDescriptions']");
          const customField = row.querySelector(".custom-deliverable");
          const customInput = row.querySelector("input[name='itemCustomDescriptions']");

          function syncCustomField() {
            const showCustom = select.value === "Custom";
            customField.style.display = showCustom ? "" : "none";
            customInput.required = showCustom;
          }

          select.addEventListener("change", syncCustomField);
          syncCustomField();

          row.querySelectorAll("input, select").forEach((input) => {
            bindLiveInput(input);
          });

          row.addEventListener("input", calculateTotal);
          return row;
        }

        function distributeAmounts() {
          const qtyInputs = Array.from(document.querySelectorAll("input[name='itemQuantities']"));
          const amountInputs = Array.from(document.querySelectorAll("input[name='itemAmounts']"));
          const quantities = qtyInputs.map((input) => Number(input.value || 0));
          const totalQuantity = quantities.reduce((sum, value) => sum + value, 0);

          if (!amountInputs.length) return;

          if (totalQuantity <= 0) {
            amountInputs.forEach((input) => {
              input.value = Number(0).toFixed(2);
            });
            return;
          }

          let assigned = 0;
          amountInputs.forEach((input, index) => {
            if (index === amountInputs.length - 1) {
              const finalShare = Number((lockedAmount - assigned).toFixed(2));
              input.value = finalShare.toFixed(2);
              return;
            }

            const share = Number(((lockedAmount * quantities[index]) / totalQuantity).toFixed(2));
            assigned = Number((assigned + share).toFixed(2));
            input.value = share.toFixed(2);
          });
        }

        function calculateTotal() {
          const amountInputs = Array.from(document.querySelectorAll("input[name='itemAmounts']"));
          distributeAmounts();
          let total = 0;
          for (let i = 0; i < amountInputs.length; i += 1) {
            total += Number(amountInputs[i].value || 0);
          }
          computedTotal.value = total.toFixed(2);
          syncAllPreviewFields();
        }

        function updateDeleteButtons() {
          const allRows = rowsWrap.querySelectorAll('.invoice-row-wrap');
          allRows.forEach(r => {
            const btn = r.querySelector('.delete-row-btn');
            if (btn) btn.style.display = allRows.length <= 1 ? 'none' : '';
          });
        }

        function addRow(item = {}) {
          const row = rowTemplate(item);
          // Wire delete button
          const delBtn = row.querySelector('.delete-row-btn');
          if (delBtn) {
            delBtn.addEventListener('click', () => {
              row.style.transform = 'scale(0.96)';
              row.style.opacity = '0';
              row.style.transition = 'transform 0.18s ease, opacity 0.18s ease';
              setTimeout(() => {
                row.remove();
                calculateTotal();
                updateDeleteButtons();
              }, 180);
            });
          }
          rowsWrap.appendChild(row);
          updateDeleteButtons();
          return row;
        }

        addRowBtn.addEventListener("click", () => {
          addRow();
          calculateTotal();
        });

        if (initialItems.length) {
          initialItems.forEach((item) => addRow(item));
        } else {
          addRow();
        }
        calculateTotal();
        updateDeleteButtons();

        // Smooth Quadratic Bezier Canvas Drawing
        const canvas = document.getElementById("signPad");
        const ctx = canvas.getContext("2d");
        let drawing = false;
        let strokes = [];
        let currentStroke = [];

        function pointFromEvent(e) {
          const rect = canvas.getBoundingClientRect();
          const x = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left;
          const y = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top;
          return { x, y };
        }

        function redrawCanvas() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.lineWidth = 2.5;
          ctx.lineCap = "round";
          ctx.lineJoin = "round";
          ctx.strokeStyle = "#111";

          strokes.forEach((stroke) => {
            if (stroke.length < 1) return;
            ctx.beginPath();
            ctx.moveTo(stroke[0].x, stroke[0].y);

            if (stroke.length < 3) {
              if (stroke[1]) ctx.lineTo(stroke[1].x, stroke[1].y);
              ctx.stroke();
              return;
            }

            for (let i = 1; i < stroke.length - 2; i++) {
              const xc = (stroke[i].x + stroke[i + 1].x) / 2;
              const yc = (stroke[i].y + stroke[i + 1].y) / 2;
              ctx.quadraticCurveTo(stroke[i].x, stroke[i].y, xc, yc);
            }

            ctx.quadraticCurveTo(
              stroke[stroke.length - 2].x,
              stroke[stroke.length - 2].y,
              stroke[stroke.length - 1].x,
              stroke[stroke.length - 1].y
            );
            ctx.stroke();
          });
        }

        function updatePreviewSignature() {
          const prevImg = document.getElementById("prevSignatureImg");
          const base64 = canvas.toDataURL("image/png");
          if (strokes.length > 0) {
            prevImg.src = base64;
            prevImg.style.display = "block";
          } else {
            prevImg.src = "";
            prevImg.style.display = "none";
          }
        }

        function startDraw(e) {
          drawing = true;
          const p = pointFromEvent(e);
          currentStroke = [p];
          strokes.push(currentStroke);
          redrawCanvas();
        }

        function moveDraw(e) {
          if (!drawing) return;
          e.preventDefault();
          const p = pointFromEvent(e);
          currentStroke.push(p);
          redrawCanvas();
        }

        function endDraw() {
          if (drawing) {
            drawing = false;
            updatePreviewSignature();
          }
        }

        canvas.addEventListener("mousedown", startDraw);
        canvas.addEventListener("mousemove", moveDraw);
        canvas.addEventListener("mouseup", endDraw);
        canvas.addEventListener("mouseleave", endDraw);
        canvas.addEventListener("touchstart", startDraw, { passive: false });
        canvas.addEventListener("touchmove", moveDraw, { passive: false });
        canvas.addEventListener("touchend", endDraw);

        document.getElementById("clearSign").addEventListener("click", () => {
          strokes = [];
          currentStroke = [];
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          updatePreviewSignature();
        });

        // Handle signature upload file sync
        document.getElementById("signatureFile").addEventListener("change", (e) => {
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = (evt) => {
              const prevImg = document.getElementById("prevSignatureImg");
              prevImg.src = evt.target.result;
              prevImg.style.display = "block";
            };
            reader.readAsDataURL(file);
          }
        });

        // Submit form validation
        formEl.addEventListener("submit", (e) => {
          calculateTotal();

          if (!validateCurrentStep()) {
            e.preventDefault();
            alert("Please correct the validation errors in the fields.");
            return;
          }

          const signatureFile = document.getElementById("signatureFile");
          const signatureHasUpload = signatureFile && signatureFile.files.length > 0;

          if (strokes.length === 0 && !signatureHasUpload) {
            e.preventDefault();
            alert("Draw or upload signature is mandatory.");
            return;
          }

          if (submitBtn) {
            submitBtn.dataset.loading = "true";
            submitBtn.disabled = true;
          }

          const total = Number(computedTotal.value || 0);
          if (Number(total.toFixed(2)) !== Number(lockedAmount.toFixed(2))) {
            e.preventDefault();
            if (submitBtn) {
              submitBtn.dataset.loading = "false";
              submitBtn.disabled = false;
            }
            alert("Row total must exactly match predefined creator amount.");
            return;
          }

          if (strokes.length > 0) {
            const signatureDraw = document.getElementById("signatureDraw");
            signatureDraw.value = canvas.toDataURL("image/png");
          }
        });

        // Initialize preview fields on page load
        syncAllPreviewFields();
      </script>
    <% } %>
  </body>
</html>
