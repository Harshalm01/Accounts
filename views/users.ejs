<!doctype html>
<html>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Users — 3Folks Media</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/public/styles.css?v=45" />
  <style>
    .input-container {
      display: flex;
      background: white;
      border-radius: 1rem;
      background: linear-gradient(135deg, #23272F 0%, #14161a 100%);
      box-shadow: 10px 10px 20px #0e1013, -10px -10px 40px #383e4b;
      padding: 0.3rem;
      gap: 0.3rem;
    }

    .input-container input {
      border-radius: 0.8rem 0 0 0.8rem;
      background: #23272F;
      box-shadow: inset 5px 5px 10px #0e1013, inset -5px -5px 10px #383e4b, 0px 0px 100px rgba(255, 212, 59, 0), 0px 0px 100px rgba(255, 102, 0, 0);
      width: 100%;
      flex-basis: 75%;
      padding: 1rem;
      border: none;
      border: 1px solid transparent;
      color: white;
      transition: all 0.2s ease-in-out;
      font-family: inherit;
      font-size: 14px;
    }

    .input-container input:focus {
      border: 1px solid #FFD43B;
      outline: none;
      box-shadow: inset 0px 0px 10px rgba(255, 102, 0, 0.5), inset 0px 0px 10px rgba(255, 212, 59, 0.5), 0px 0px 100px rgba(255, 212, 59, 0.5), 0px 0px 100px rgba(255, 102, 0, 0.5);
    }

    .input-container button {
      flex-basis: 25%;
      padding: 1rem;
      background: linear-gradient(135deg, rgb(255, 212, 59) 0%, rgb(255, 102, 0) 100%);
      box-shadow: 0px 0px 1px rgba(255, 212, 59, 0.5), 0px 0px 1px rgba(255, 102, 0, 0.5);
      font-weight: 900;
      letter-spacing: 0.3rem;
      text-transform: uppercase;
      color: #23272F;
      border: none;
      width: 100%;
      border-radius: 0 1rem 1rem 0;
      transition: all 0.2s ease-in-out;
      cursor: pointer;
      font-family: inherit;
    }

    .input-container button:hover {
      background: linear-gradient(135deg, rgb(255, 212, 59) 50%, rgb(255, 102, 0) 100%);
      box-shadow: 0px 0px 100px rgba(255, 212, 59, 0.5), 0px 0px 100px rgba(255, 102, 0, 0.5);
    }

    @media (max-width: 500px) {
      .input-container {
        flex-direction: column;
      }

      .input-container input {
        border-radius: 0.8rem;
      }

      .input-container button {
        padding: 1rem;
        border-radius: 0.8rem;
      }
    }
  </style>
</head>

<body class="admin-page">
  <div class="shell">

    <!-- Hero Banner Header -->
    <div class="topbar hero-banner folder-header-banner">
      <div class="header-left">
        <%- include('partials/brand') %>
          <div class="eyebrow">Super Admin</div>
          <h2 style="margin: 8px 0 6px 0;">User Management</h2>
          <p class="subtitle" style="color: #4B5563 !important;">Create users, assign roles and reset passwords.</p>
      </div>

      <div class="header-right">
        <div class="header-actions-row">
          <a href="/admin/dashboard"><button class="btn btn-3d-nav" type="button">← Back</button></a>
        </div>
        <div class="header-stats-grid">
          <div class="header-stat-card">
            <span class="stat-icon">👤</span>
            <div class="stat-info">
              <span class="stat-value">
                <%= users.length %>
              </span>
              <span class="stat-label">Total Users</span>
            </div>
          </div>
          <div class="header-stat-card">
            <span class="stat-icon">🛡️</span>
            <div class="stat-info">
              <span class="stat-value">
                <%= users.filter(u=>u.role==='SUPER_ADMIN').length %>
              </span>
              <span class="stat-label">Super Admins</span>
            </div>
          </div>
          <div class="header-stat-card">
            <span class="stat-icon">🏷️</span>
            <div class="stat-info">
              <span class="stat-value">
                <%= users.filter(u=>u.role==='TEAM').length %>
              </span>
              <span class="stat-label">Team Users</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">
        <%= error %>
      </div>
      <% } %>

        <!-- SuperAdmin Creator Global Search Engine & Campaign Ledger -->
        <div class="card glass-panel" style="margin-bottom: 24px; padding: 28px 32px;">
          <div class="section-head" style="margin-bottom: 20px;">
            <div>
              <div style="font-size: 11px; font-weight: 800; text-transform: uppercase; color: #7c3aed; letter-spacing: 1.5px; margin-bottom: 4px;">
                👑 SuperAdmin Exclusive Engine
              </div>
              <h3 style="font-size: 22px; font-weight: 850; color: #0f172a; margin: 0;">
                Creator Global Search & Campaign Ledger
              </h3>
              <p class="subtitle" style="margin-top: 4px; font-size: 13px; color: #64748b;">
                Search any creator name to view creator details, campaign history, amounts, and creation date/year.
              </p>
            </div>
            <div class="pill" id="creatorFoundBadge" style="background: #f3e8ff; color: #7c3aed; font-weight: 800;">
              <%= creatorLedger ? creatorLedger.length : 0 %> records
            </div>
          </div>

          <!-- EXACT USER SEARCH BAR COMPONENT -->
          <div class="input-container" style="margin-bottom: 24px;">
            <input type="text" id="creatorSearchInput" placeholder="SEARCH CREATOR NAME (e.g. Harshal, Shubh, xyz)..." onkeyup="performCreatorSearch()" />
            <button type="button" class="button" onclick="performCreatorSearch()">SEARCH</button>
          </div>

          <!-- CREATOR SEARCH RESULTS TABLE -->
          <div class="users-table-wrap">
            <table class="users-table" id="creatorLedgerTable">
              <thead>
                <tr>
                  <th>Creator Name</th>
                  <th>Campaign Name</th>
                  <th>Invoice Amount (₹)</th>
                  <th>Campaign Date & Year</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="creatorLedgerBody">
                <% if (!creatorLedger || !creatorLedger.length) { %>
                  <tr><td colspan="6" style="text-align: center; color: #64748b; padding: 30px;">No creator invoice records found in database.</td></tr>
                <% } else { %>
                  <% creatorLedger.forEach((row) => { %>
                    <% 
                      const rawDate = row.campaign_created_at || row.invoice_date || Date.now();
                      const d = new Date(rawDate);
                      const formattedDate = !isNaN(d.getTime()) ? d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A';
                      const yearStr = !isNaN(d.getTime()) ? d.getFullYear() : 'N/A';
                      const displayAmount = row.final_amount || row.total_amount || 0;
                    %>
                    <tr class="creator-ledger-row" data-search="<%= (row.creator_name + ' ' + row.campaign_name + ' ' + yearStr + ' ' + (row.creator_mobile || '')).toLowerCase() %>">
                      <td data-label="Creator Name">
                        <strong style="color: #0f172a; font-size: 14px;"><%= row.creator_name %></strong><br/>
                        <span style="font-size: 11px; color: #64748b;"><%= row.creator_mobile || 'No Mobile' %></span>
                      </td>
                      <td data-label="Campaign Name">
                        <strong style="color: #1e293b; font-size: 13px;"><%= row.campaign_name || 'Campaign' %></strong><br/>
                        <span class="pill" style="font-size: 10px; background: #f1f5f9; color: #475569; padding: 2px 8px;"><%= row.campaign_code || 'N/A' %></span>
                      </td>
                      <td data-label="Invoice Amount">
                        <span style="font-weight: 800; font-family: monospace; color: #0f172a; font-size: 14px;">
                          ₹<%= Number(displayAmount).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                        </span>
                      </td>
                      <td data-label="Campaign Date & Year">
                        <div style="font-weight: 700; color: #334155; font-size: 13px;"><%= formattedDate %></div>
                        <span style="font-size: 11px; font-weight: 800; color: #7c3aed; background: #f3e8ff; padding: 2px 8px; border-radius: 4px; display: inline-block; margin-top: 2px;">
                          Year <%= yearStr %>
                        </span>
                      </td>
                      <td data-label="Status">
                        <span class="status-pill <%= row.invoice_status %>" style="font-size: 11px; font-weight: 700;">
                          <%= row.invoice_status %>
                        </span>
                      </td>
                      <td data-label="Action">
                        <a href="/admin/invoices/<%= row.invoice_id %>" class="btn btn-3d-sm btn-3d-open" style="padding: 6px 14px; font-size: 12px;">👁️ View Invoice</a>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Add User Form -->
        <div class="card glass-panel" style="margin-bottom: 16px;">
          <div class="section-head" style="margin-bottom: 20px;">
            <div>
              <h3>Add User</h3>
              <p class="subtitle">Create a new portal user with a role and optional team assignment.</p>
            </div>
          </div>
          <form method="post" action="/admin/users" class="portal-form">
            <div class="grid-3" style="margin-bottom: 0;">
              <label class="input-label">
                <span>Username *</span>
                <input type="text" name="username" required placeholder="e.g. john_accounts" />
              </label>
              <label class="input-label">
                <span>Password *</span>
                <input type="password" name="password" required placeholder="Min 8 characters" />
              </label>
              <label class="input-label">
                <span>Role *</span>
                <select name="role" required>
                  <option value="" disabled selected>Select Role...</option>
                  <option value="TEAM">TEAM</option>
                  <option value="ACCOUNTS">ACCOUNTS</option>
                  <option value="SUPER_ADMIN">SUPER_ADMIN</option>
                </select>
              </label>
            </div>

            <!-- Folding Row for Team Name -->
            <div class="accordion-row-container" style="perspective: 1000px;">
              <div class="accordion-row" id="teamNameWrapper"
                style="max-height: 0; opacity: 0; transform: rotateX(-90deg); transform-origin: top center; transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden;">
                <div style="padding: 16px 0 8px 0; border-top: 1px dashed rgba(15, 23, 42, 0.08); margin-top: 16px;">
                  <label class="input-label" style="max-width: 320px; display: block;">
                    <span>Team Name (for TEAM role) *</span>
                    <input type="text" name="teamName" placeholder="e.g. TEAM_1"
                      style="width: 100%; margin-top: 6px;" />
                  </label>
                </div>
              </div>
            </div>

            <div style="margin-top: 16px; display: flex; justify-content: flex-end;">
              <button class="btn btn-3d-nav" type="submit" style="width: auto; min-width: 200px;">+ Create User</button>
            </div>
          </form>
        </div>

        <!-- Users Table -->
        <div class="card glass-panel">
          <div class="section-head" style="margin-bottom: 20px;">
            <div>
              <h3>All Users</h3>
              <p class="subtitle">Manage existing portal users — reset passwords or remove access.</p>
            </div>
            <div class="pill">
              <%= users.length %> users
            </div>
          </div>

          <div class="users-table-wrap">
            <table class="users-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Role</th>
                  <th>Team</th>
                  <th>Impersonate</th>
                  <th>Reset Password</th>
                  <th>Delete</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((u)=> { %>
                  <tr>
                    <td class="user-id-cell" data-label="#">
                      <%= u.id %>
                    </td>
                    <td data-label="Username">
                      <div class="user-name-cell">
                        <div class="user-avatar" data-name="<%= u.username %>">
                          <%= u.username.charAt(0).toUpperCase() %>
                        </div>
                        <span>
                          <%= u.username %>
                        </span>
                      </div>
                    </td>
                    <td data-label="Role">
                      <span class="role-badge role-<%= u.role.toLowerCase() %>">
                        <%= u.role %>
                      </span>
                    </td>
                    <td class="team-cell" data-label="Team">
                      <%= u.team_name || '—' %>
                    </td>
                    <td data-label="Impersonate">
                      <% if (u.id !==user.id) { %>
                        <form method="post" action="/admin/users/<%= u.id %>/impersonate">
                          <button class="btn btn-3d-sm btn-3d-view" type="submit">Impersonate</button>
                        </form>
                        <% } else { %>
                          <span style="color: #9ca3af; font-size: 13px; font-weight: 500;">Current User</span>
                          <% } %>
                    </td>
                    <td data-label="Reset Password">
                      <form method="post" action="/admin/users/<%= u.id %>/reset"
                        style="display:flex;gap:8px;align-items:center;">
                        <input type="password" name="newPassword" placeholder="New password" required
                          style="flex:1;min-width:140px;" />
                        <button class="btn btn-3d-sm btn-3d-view" type="submit">Reset</button>
                      </form>
                    </td>
                    <td data-label="Delete">
                      <form method="post" action="/admin/users/<%= u.id %>/delete"
                        onsubmit="return confirm('Delete user <%= u.username %>?')">
                        <button class="btn btn-3d-sm btn-3d-reject" type="submit">Delete</button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <script>
          window.performCreatorSearch = function () {
            const input = document.getElementById('creatorSearchInput');
            const filter = (input ? input.value : '').toLowerCase().trim();
            const rows = document.querySelectorAll('.creator-ledger-row');
            let visibleCount = 0;

            rows.forEach(row => {
              const searchData = row.getAttribute('data-search') || '';
              if (!filter || searchData.includes(filter)) {
                row.style.display = '';
                visibleCount++;
              } else {
                row.style.display = 'none';
              }
            });

            const badge = document.getElementById('creatorFoundBadge');
            if (badge) {
              badge.innerText = visibleCount + ' records found';
            }
          };

          document.addEventListener("DOMContentLoaded", () => {
            const roleSelect = document.querySelector('select[name="role"]');
            const teamNameWrapper = document.getElementById("teamNameWrapper");
            const teamNameInput = teamNameWrapper ? teamNameWrapper.querySelector('input[name="teamName"]') : null;

            function toggleTeamInput() {
              if (!roleSelect || !teamNameWrapper) return;
              const isTeam = roleSelect.value === "TEAM";
              if (isTeam) {
                teamNameWrapper.style.maxHeight = "120px";
                teamNameWrapper.style.opacity = "1";
                teamNameWrapper.style.transform = "rotateX(0deg)";
                if (teamNameInput) teamNameInput.required = true;
              } else {
                teamNameWrapper.style.maxHeight = "0";
                teamNameWrapper.style.opacity = "0";
                teamNameWrapper.style.transform = "rotateX(-90deg)";
                if (teamNameInput) {
                  teamNameInput.required = false;
                  teamNameInput.value = "";
                }
              }
            }

            if (roleSelect) {
              roleSelect.addEventListener("change", toggleTeamInput);
              // Initialize on load
              toggleTeamInput();
            }

            // Feature #16 — Color-coded avatars (deterministic by name hash)
            (function colorAvatars() {
              const PALETTES = [
                ['#7c3aed', '#4f46e5'],
                ['#db2777', '#9333ea'],
                ['#0891b2', '#0e7490'],
                ['#d97706', '#b45309'],
                ['#16a34a', '#15803d'],
                ['#dc2626', '#b91c1c'],
                ['#0284c7', '#0369a1'],
                ['#c026d3', '#a21caf'],
                ['#ea580c', '#c2410c'],
                ['#65a30d', '#4d7c0f'],
              ];
              function hashName(str) {
                let h = 0;
                for (let i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) | 0;
                return Math.abs(h);
              }
              document.querySelectorAll('.user-avatar[data-name]').forEach(el => {
                const name = el.dataset.name || '';
                const [c1, c2] = PALETTES[hashName(name) % PALETTES.length];
                el.style.background = `linear-gradient(135deg, ${c1}, ${c2})`;
              });
            })();
          });
        </script>

  </div>
</body>

</html>
